# SportsGameOdds API key (https://sportsgameodds.com — free tier available).
# Used for MLB pitcher strikeout props. Without a key the slate still builds
# from MLB StatsAPI; book odds columns are just left empty.
SPORTSGAMEODDS_API_KEY=

# MLB season used for season-to-date pitcher/team stats.
MLB_SEASON=2026

# CORS origin for the Vite dev server (the frontend also proxies /api, so this
# is mainly for hitting the API directly).
FRONTEND_ORIGIN=http://localhost:5174
